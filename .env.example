# Azure OpenAI Configuration
AZURE_API_KEY=your_azure_api_key_here
AZURE_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/openai/responses
AZURE_API_VERSION=2025-04-01-preview
AZURE_MODEL=gpt-5.2-codex

# GitHub Configuration - REQUIRED for repo fetching
# The system will clone/fetch this repository and read all files
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username_or_org
GITHUB_REPO_NAME=your_repository_name
GITHUB_BASE_BRANCH=main
